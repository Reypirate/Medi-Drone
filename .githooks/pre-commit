#!/usr/bin/env python3
"""
Pre-commit Git Hook - Documentation Check

Automatically runs before each git commit to check if documentation
needs to be updated based on code changes.

Usage: This hook is automatically triggered by: git commit
To bypass: git commit --no-verify
"""

import sys
import os
import subprocess
from pathlib import Path

# Get the repository root directory (hook is in .githooks/, need to go up 1 level)
REPO_ROOT = Path(__file__).parent.parent.resolve()
SCRIPT_PATH = REPO_ROOT / "scripts" / "sync_docs.py"

def get_staged_files():
    """Get list of staged files that will be committed."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
        capture_output=True,
        text=True,
        cwd=REPO_ROOT
    )
    return result.stdout.strip().split("\n") if result.stdout.strip() else []

def main():
    print("\n" + "="*70)
    print("Documentation Check - Pre-commit Hook")
    print("="*70)

    # Get staged files
    staged_files = get_staged_files()

    # Check if any relevant service files are being committed
    relevant_files = [
        "drone_dispatch.py",
        "drone_management.py",
        "order.py",
        "weather.py",
        "route_planning.py",
        "app.js"
    ]

    has_relevant_changes = any(
        any(f in file for f in relevant_files)
        for file in staged_files
    )

    if not has_relevant_changes:
        print("No relevant service files changed. Skipping documentation check.")
        return 0

    print("\nRelevant service files detected. Running documentation gap analysis...\n")

    # Run the sync_docs script directly
    if not SCRIPT_PATH.exists():
        print(f"Warning: Documentation script not found at {SCRIPT_PATH}")
        return 0

    # Run the script and capture output
    result = subprocess.run(
        [sys.executable, str(SCRIPT_PATH)],
        capture_output=True,
        text=True,
        cwd=REPO_ROOT
    )

    # Print the output
    print(result.stdout)

    if result.stderr:
        print(result.stderr, file=sys.stderr)

    # Check if there were any critical/important gaps
    # The sync_docs.py script exits with 0 for success, but we need to parse output
    output = result.stdout.lower()

    critical_indicators = ["critical (", "action required"]
    important_indicators = ["important ("]

    has_critical = any(indicator in output for indicator in critical_indicators)
    has_important = any(indicator in output for indicator in important_indicators)
    has_gaps = "total gaps found:" in output and "total gaps found: 0" not in output

    if has_critical or has_important:
        print("\n" + "="*70)
        print("ACTION REQUIRED")
        print("="*70)
        print("\nYour code changes have introduced documentation gaps!")
        print("\nPlease update the documentation before committing:")
        print("  - README.md")
        print("  - docs/system-flow.md")
        print("\nOr run: git check-docs --verbose for details")
        print("\nTo bypass this check: git commit --no-verify")
        print("="*70)
        return 1

    if has_gaps:
        print("\n" + "="*70)
        print("INFO: Minor documentation gaps detected")
        print("="*70)
        print("\nConsider updating documentation when convenient:")
        print("  git check-docs --verbose")
        print("="*70)

    print("\n" + "="*70)
    print("Pre-commit check complete!")
    print("="*70)
    return 0

if __name__ == "__main__":
    sys.exit(main())
