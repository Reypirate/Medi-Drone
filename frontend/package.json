{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "NODE_ENV=production bun build/index.js",
    "build": "bun run load-env -- vite build && tsc && bun build --minify --sourcemap --target=bun --outdir=build server/index.ts",
    "build:docker": "bun run build && docker build -t medi-drone-frontend .",
    "load-env": "dotenv -e .env",
    "lint": "oxlint .",
    "format": "oxfmt -w .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@vis.gl/react-google-maps": "^1.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.12",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.167.12",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "oxlint": "^1.59.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
